# Python
__pycache__/
*.py[cod]
*.so

# Virtual environment
.venv/

# uv
uv.lock

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Qdrant storage (large binary data, not for git)
**/data/qdrant_storage/

# Build artifacts (reproducible via make)
*.o
*.bin
*.elf
*.hex
*.map

# Hugging Face model cache
models--*/

# Evaluation/skill testing workspace (generated at runtime, not committed)
**/workspace/

# Build pipeline outputs (generated at runtime, not committed)
**/data/raw/*.pdf
**/data/parsed/*
!**/data/parsed/.gitkeep
!**/data/raw/.gitkeep
